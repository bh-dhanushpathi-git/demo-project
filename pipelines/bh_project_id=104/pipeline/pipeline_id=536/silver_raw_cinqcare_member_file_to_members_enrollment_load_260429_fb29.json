          {
            "name": "region",
            "expression": "CASE WHEN MEMBER_STATE_src_1 IN ('ME', 'NH', 'VT', 'MA', 'RI', 'CT', 'NY', 'NJ', 'PA') THEN 'Northeast' WHEN MEMBER_STATE_src_1 IN ('WV', 'VA', 'KY', 'TN', 'NC', 'SC', 'GA', 'FL', 'AL', 'MS', 'AR', 'LA') THEN 'Southeast' WHEN MEMBER_STATE_src_1 IN ('OH', 'IN', 'IL', 'MI', 'WI', 'MN', 'IA', 'MO', 'ND', 'SD', 'NE', 'KS') THEN 'Midwest' WHEN MEMBER_STATE_src_1 IN ('MT', 'ID', 'WY', 'NV', 'UT', 'CO', 'AZ', 'NM', 'AK', 'WA', 'OR', 'CA', 'HI') THEN 'West' ELSE 'Unknown' END"
          },
          {
            "name": "can_contact",
            "expression": "true"
          },
          {
            "name": "county",
            "expression": "MEMBER_REGION_src_1"
          },
          {
            "name": "zip4",
            "expression": "CASE WHEN length(CAST(MEMBER_ZIP_src_1 AS STRING)) > 5 THEN substring(CAST(MEMBER_ZIP_src_1 AS STRING), 6, 4) ELSE NULL END"
          },
          {
            "name": "is_zip4",
            "expression": "'FALSE'"
          },
