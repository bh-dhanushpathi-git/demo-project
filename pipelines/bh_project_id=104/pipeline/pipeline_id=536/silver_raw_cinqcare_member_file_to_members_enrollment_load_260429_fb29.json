            "name": "updated_at",
            "expression": "current_timestamp()"
          },
          {
            "name": "hash_scd1",
            "expression": "md5(concat(coalesce(MEMBER_NAME_src_1, ''), '|', coalesce(CAST(MEMBER_DOB_src_1 AS STRING), ''), '|', coalesce(MEMBER_SEX_src_1, ''), '|', coalesce(MEMBER_ADDRESS_1_src_1, ''), '|', coalesce(MEMBER_CITY_src_1, ''), '|', coalesce(MEMBER_STATE_src_1, ''), '|', coalesce(CAST(MEMBER_ZIP_src_1 AS STRING), '')))"
          }
